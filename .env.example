# Copy to .env per node (or set inline) to run a cluster locally.

# Unique id for this node.
NODE_ID=node1

# HTTP port this node listens on.
PORT=3001

# OTHER nodes in the cluster, as "id@url" comma-separated.
# Leave empty for a single-node cluster (it elects itself leader).
PEERS=node2@http://localhost:3002,node3@http://localhost:3003

# Optional Raft timer tuning (milliseconds).
# ELECTION_MIN_MS=150
# ELECTION_MAX_MS=300
# HEARTBEAT_MS=50

# Set to "true" to log role/term changes.
# RAFT_DEBUG=false
