{
    "compilerOptions": {
        "target": "ES2017",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "resolveJsonModule": true,
        "outDir": "./dist",
        "sourceMap": true
    },
    "include": ["./src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}

